        "import pandas as pd\n",
        "from sklearn.metrics import accuracy_score, confusion_matrix, classification_report\n",
        "import torch\n",
        "\n",
        "\n",
        "ig = pd.read_csv(\"instagram_test.csv\")\n",
        "ig = ig.rename(columns={\"comment\": \"comment_text\"})\n",
        "ig = ig[ig[\"label\"].notna()].copy()\n",
        "ig[\"label\"] = ig[\"label\"].astype(int)\n",
        "print(\"Loaded:\", len(ig), \"comments\")\n",
        "print(ig[\"label\"].value_counts())\n",
        "\n",
        "\n",
        "ig_enc = tokenizer(\n",
        "    list(ig[\"comment_text\"].astype(str)),\n",
        "    truncation=True, padding=True, max_length=140, return_tensors=\"pt\"\n",
        ")\n",
        "\n",
        "# evaluation mode\n",
        "model.eval()\n",
        "with torch.no_grad():\n",
        "    ig_enc = {k: v.to(model.device) for k, v in ig_enc.items()}\n",
        "    logits = model(**ig_enc).logits\n",
        "    ig_preds = logits.argmax(-1).cpu().numpy()\n",
        "\n",
        "print(\"\\n--- Instagram (cross-platform) results ---\")\n",
        "print(\"Accuracy:\", accuracy_score(ig[\"label\"], ig_preds))\n",
        "print()\n",
        "print(confusion_matrix(ig[\"label\"], ig_preds))\n",
        "print()\n",
        "print(classification_report(ig[\"label\"], ig_preds, target_names=[\"not-intent (0)\", \"buy-intent (1)\"]))"
