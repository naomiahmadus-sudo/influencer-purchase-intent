        "# we create an instance of he analyzer and then define it, turning the machine on\n",
        "analyzer = SentimentIntensityAnalyzer()\n",
        "\n",
        "# VADER scores each comment; we convert its score to a 0/1 prediction\n",
        "#custom python function to read the ext one att a time\n",
        "\n",
        "def vader_predict(text):\n",
        "    score = analyzer.polarity_scores(str(text))['compound']\n",
        "    # treat any positive sentiment as a \"buy intent\" guess — this is the naive approach\n",
        "    return 1 if score > 0.05 else 0\n",
        "\n",
        "df['vader_pred'] = df['comment_text'].apply(vader_predict)\n",
        "\n",
        "\n",
        "from sklearn.metrics import accuracy_score, confusion_matrix, classification_report\n",
        "\n",
        "print(\"VADER accuracy:\", accuracy_score(df['label'], df['vader_pred']))\n",
        "print()\n",
        "print(confusion_matrix(df['label'], df['vader_pred']))\n",
        "print()\n",
        "print(classification_report(df['label'], df['vader_pred']))"
